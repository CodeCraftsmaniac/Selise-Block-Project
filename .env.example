# Vite environment variables - copy to .env and fill in real values
# NEVER commit .env with real secrets

# Base API URL for SELISE Blocks services
VITE_API_BASE_URL=https://api.seliseblocks.com

# Project Key from Blocks Cloud portal
VITE_X_BLOCKS_KEY=your_project_key_here

# Application domain (from Blocks Cloud portal > Deployments)
VITE_APP_DOMAIN=https://your-app-domain.seliseblocks.com

# OIDC redirect URI (must match configuration in Blocks Cloud)
VITE_BLOCKS_OIDC_REDIRECT_URI=https://your-app-domain.seliseblocks.com/oidc

# Project slug (short identifier from Blocks Cloud)
VITE_PROJECT_SLUG=your_project_slug

# CAPTCHA configuration (optional - leave empty if disabled)
VITE_CAPTCHA_SITE_KEY=
VITE_CAPTCHA_TYPE=reCaptcha

# Blocks OIDC Client ID (optional - leave empty if not using OIDC)
VITE_BLOCKS_OIDC_CLIENT_ID=

# Disable source maps in production
GENERATE_SOURCEMAP=false
